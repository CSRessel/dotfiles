# https://www.dafont.com/verily-serif-mono.font (Serif for presentation or similar)
# font-family = Verily Serif Mono
# https://www.nerdfonts.com/font-downloads (daily driver)
font-family = FiraCode Nerd Font

theme = Catppuccin Mocha

# Clashes with lunarvim terminals:
keybind = alt+one=unbind
keybind = alt+two=unbind
keybind = alt+three=unbind
keybind = alt+four=unbind

# Stick with CSI-u sequence as it's the most up-to-date and best supported
keybind = shift+enter=csi:13;2u
keybind = shift+space=text:\x20
keybind = shift+`=text:~

window-decoration = none
